{
  "name": "app-01-shop-quote-studio",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev:client": "vite --config client/vite.config.ts",
    "dev:server": "tsx watch server/src/server.ts",
    "start": "concurrently -n client,server -c cyan,green \"npm run dev:client\" \"npm run dev:server\"",
    "build": "vite build --config client/vite.config.ts && tsc -p server/tsconfig.json",
    "start:prod": "NODE_ENV=production node server/dist/server.js",
    "preview": "vite preview --config client/vite.config.ts --port 5173",
    "test": "vitest run --config server/vitest.config.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.1",
    "vitest": "^2.1.6"
  }
}
